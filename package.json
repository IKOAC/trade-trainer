{
  "name": "trade-trainer",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "next build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "lint": "next lint",
    "download:data": "node scripts/download_market_data.js",
    "generate:dataset": "node scripts/generate_training_data.js",
    "release:docker:build": "docker build -t trade-trainer:latest .",
    "release:docker:run": "docker run --rm -p 3000:3000 trade-trainer:latest"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "express": "^4.21.2",
    "lightweight-charts": "^4.2.3",
    "next": "14.2.24",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.9",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
